        <light directional="false" diffuse="0.0 0.8 1.0" specular="0.0 0.8 1.0" pos="0 0 5" dir="0 0 -1" castshadow="true"/>
        <light directional="false" diffuse="0.8 0.0 1.0" specular="0.8 0.0 1.0" pos="-4 -4 4" dir="0 0 -1" castshadow="false"/>

        <!-- Neon-grid Ground Platform (Rough Martian/Lunar Terrain) -->
        <geom name="floor" type="hfield" hfield="terrain" material="grid_mat" condim="3"/>

