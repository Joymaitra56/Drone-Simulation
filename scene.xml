<mujoco model="Neon Grid Space Simulation">
    <compiler coordinate="local" angle="degree" inertiafromgeom="true"/>
    <option gravity="0 0 -9.81" timestep="0.005"/>

    <asset>
        <!-- Load the custom neon grid texture -->
        <texture name="grid_tex" type="2d" file="grid_pattern.png"/>
        <!-- Create a dark gradient skybox for futuristic cyberpunk atmosphere -->
        <texture name="sky_tex" type="skybox" builtin="gradient" rgb1="0.02 0.04 0.08" rgb2="0.005 0.01 0.015" width="512" height="512"/>
        
        <!-- Materials mapping -->
        <material name="grid_mat" texture="grid_tex" texrepeat="5 5" texuniform="true" roughness="0.9" specular="0.1"/>
        <material name="glow_cyan" rgba="0.0 0.8 1.0 0.8" emission="0.8" roughness="0.1" specular="0.9"/>
        <material name="glow_blue" rgba="0.0 0.3 1.0 0.9" emission="0.8"/>
        <material name="metal_dark" rgba="0.1 0.12 0.15 1.0" roughness="0.2" specular="0.8"/>
        <material name="rock_mat" rgba="0.18 0.16 0.15 1.0" roughness="0.95" specular="0.05"/>
        <material name="glow_magenta" rgba="0.9 0.0 0.8 0.8" emission="0.8"/>
        <material name="metal_light" rgba="0.6 0.65 0.7 1.0" roughness="0.1" specular="0.9"/>
        <material name="rotor_green" rgba="0.0 1.0 0.4 0.4" emission="0.5"/>

        <!-- Load the rough terrain heightmap (spans 8x8m matching plane size, max height 0.4m) -->
        <hfield name="terrain" file="rough_terrain_heightmap.png" size="8 8 0.4 0.01"/>
    </asset>

